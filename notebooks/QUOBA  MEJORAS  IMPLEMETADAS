# Cotas teoricas citadas por la rubrica.
GW_GUARANTEE = 0.878        # Goemans & Williamson (1995), JACM 42(6)
QAOA_P1_GUARANTEE = 0.6924  # Farhi, Goldstone & Gutmann (2014)

# Backend por defecto; se sobreescribe con --backend.
BACKEND = "local"
EMULATOR_NAME = "H2-1E"        # nombre del emulador en Nexus (ajustar)
NEXUS_PROJECT = "isla-verde"   # nombre del proyecto Nexus (ajustar)

# ===========================================================================
# MODO DE PESO DE ARISTA
# ===========================================================================
# "acoplamiento" (por defecto): se usa el weight del JSON tal cual, que es
#     1e5/longitud_equivalente. Es un proxy del acoplamiento electrico: dos
#     subestaciones cercanas estan fuertemente acopladas y su arista pesa
#     mucho. Como Max-Cut MAXIMIZA lo cortado, secciona los acoplamientos
#     MAS fuertes.
#
# "longitud": el peso pasa a ser la longitud equivalente en km, que ya viene
#     en el JSON como edges[].length_m. Es un proxy de DEBILIDAD del enlace,
#     asi que Max-Cut secciona los enlaces mas debiles: cada isla queda
#     internamente cohesionada, que es lo que busca el islanding fisico.
#     Sigue siendo Max-Cut sobre un grafo ponderado, que es lo unico que la
#     rubrica especifica; el peso es una decision de modelado documentada.
#
# CONSECUENCIA IMPORTANTE
#     Las lineas base del JSON (fuerza bruta, greedy, Goemans-Williamson)
#     fueron calculadas con el peso de acoplamiento. Con el modo "longitud"
#     ya no sirven: dividir un corte nuevo entre un optimo viejo daria una
#     razon sin sentido. Por eso, en ese modo, este archivo RECALCULA aqui
#     mismo la fuerza bruta y el greedy sobre los pesos nuevos.
#
#     Goemans-Williamson NO se recalcula: necesita resolver una relajacion
#     SDP con cvxpy, que vive en modelador_red.py. Para tener GW con pesos
#     de longitud hay que correr el modelador con su propio --weight-mode.
#     En el modo "longitud" la etapa de comparacion se omite y se avisa.
# POR DEFECTO: "acoplamiento". Se eligio tras comparar empiricamente las dos
#     particiones optimas con comparar_criterios.py: ambos criterios seccionan
#     casi todas las lineas (Max-Cut maximiza el corte), pero el de
#     acoplamiento deja un desbalance de potencia algo menor y, sobre todo,
#     mantiene el peso con el que modelador_red.py calculo la fuerza bruta, el
#     greedy y Goemans-Williamson, de modo que la comparacion clasica completa
#     sigue siendo valida.
#     Para el criterio inverso: --weight-mode longitud
WEIGHT_MODE = "acoplamiento"


def _pesos_por_longitud(edges: list[dict]) -> list[dict]:
    """Devuelve las aristas con weight = longitud equivalente en km.

    length_m ya viene calculado por modelador_red.py y maneja bien los
    circuitos paralelos: para un solo circuito es la longitud medida, y para
    varios en paralelo es la combinacion armonica (mas acoplamiento -> menor
    longitud equivalente). Un corredor doble pesa menos, o sea que es peor
    candidato a ser cortado. Correcto para islanding.

    Se pasa a km para que los pesos queden en un rango comodo (decenas, no
    decenas de miles) y los angulos del circuito no se vayan de escala.
    """
    nuevas = []
    for a in edges:
        if "length_m" not in a:
            raise KeyError(
                "el JSON no trae edges[].length_m; el modo 'longitud' "
                "necesita ese campo. Vuelve a correr modelador_red.py"
            )
        b = dict(a)
        b["weight"] = float(a["length_m"]) / 1000.0
        nuevas.append(b)
    return nuevas


def optimo_fuerza_bruta(edges: list[dict], orden: list[str]
                        ) -> tuple[float, dict[str, int]]:
    """Mejor corte posible, recorriendo las 2^(n-1) particiones.

    Se fija el primer nodo en la isla 0 porque complementar toda una
    particion no cambia el corte: eso ahorra la mitad del trabajo. Con
    n <= 16 son 32.768 particiones, cuestion de segundos.
    """
    n = len(orden)
    mejor, mejor_bits = -np.inf, {}
    for k in range(1 << (n - 1)):
        bits = {orden[0]: 0}
        for i in range(1, n):
            bits[orden[i]] = (k >> (i - 1)) & 1
        c = valor_corte(edges, bits)
        if c > mejor:
            mejor, mejor_bits = c, dict(bits)
    return float(mejor), mejor_bits


def greedy_maxcut(edges: list[dict], orden: list[str],
                  rng: np.random.Generator) -> float:
    """Linea base voraz: arranca al azar y mueve un nodo de isla mientras
    eso mejore el corte, hasta que ningun movimiento mejore. Mismo criterio
    que el greedy de modelador_red.py, recalculado aqui sobre los pesos
    nuevos."""
    bits = {nodo: int(b) for nodo, b in
            zip(orden, rng.integers(0, 2, size=len(orden)))}
    actual = valor_corte(edges, bits)
    for _ in range(200):
        mejor_nodo, mejor_ganancia = None, 1e-12
        for nodo in orden:
            bits[nodo] ^= 1
            ganancia = valor_corte(edges, bits) - actual
            bits[nodo] ^= 1
            if ganancia > mejor_ganancia:
                mejor_nodo, mejor_ganancia = nodo, ganancia
        if mejor_nodo is None:
            break
        bits[mejor_nodo] ^= 1
        actual += mejor_ganancia
    return float(actual)



# ===========================================================================
# 1. Carga de la instancia (JSON producido por modelador_red.py)
# ===========================================================================
def cargar_instancia(scratch_dir: Path, tier: str) -> dict[str, Any] | None:
    """Lee isla_verde_{tier}.json y devuelve variable_order, h, J_upper,
    edges y el optimo exacto de fuerza bruta. None con warning si falta."""
    path = scratch_dir / f"isla_verde_{tier}.json"
    if not path.exists():
        logger.warning("[%s] no se encontro %s. Corre primero la etapa "
                       "clasica (modelador_red.py --out-dir %s)",
                       tier, path, scratch_dir)
        return None

    with open(path, "r", encoding="utf-8") as f:
        payload = json.load(f)

    try:
        variable_order = payload["variable_order"]
        edges = payload["edges"]
        optimum = float(payload["baselines"]["maxcut"]["brute_force"]["cut"])
        # Se leen solo para dejar constancia de que existen; NO se usan para
        # el circuito. Ver la nota de abajo.
        h_json = np.array(payload["ising"]["h"], dtype=np.float64)
        j_json = np.array(payload["ising"]["J_upper"], dtype=np.float64)
    except KeyError as exc:
        logger.warning("[%s] %s no tiene el campo esperado %s", tier, path, exc)
        return None

    n = len(variable_order)

    # -----------------------------------------------------------------------
    # MODO DE PESO
    # -----------------------------------------------------------------------
    # En modo "longitud" se reemplaza el peso por la longitud equivalente en
    # km y se RECALCULAN aqui la fuerza bruta y el greedy, porque las del
    # JSON corresponden al peso de acoplamiento y ya no aplican.
    # -----------------------------------------------------------------------
    greedy_local = None
    bits_opt: dict[str, int] = {}
    if WEIGHT_MODE == "longitud":
        edges = _pesos_por_longitud(edges)
        optimum, bits_opt = optimo_fuerza_bruta(edges, variable_order)
        greedy_local = greedy_maxcut(edges, variable_order,
                                     np.random.default_rng(42))
        isla_a = sorted(k for k, v in bits_opt.items() if v == 0)
        logger.info("[%s] modo LONGITUD: pesos = longitud equivalente en km. "
                    "Fuerza bruta y greedy recalculados sobre estos pesos "
                    "(optimo = %.4f, greedy = %.4f). GW del JSON NO aplica.",
                    tier, optimum, greedy_local)
        logger.info("[%s] particion optima exacta: isla A = %s",
                    tier, ", ".join(isla_a))
    else:
        logger.info("[%s] modo ACOPLAMIENTO: pesos = 1e5/longitud, tal como "
                    "los escribio modelador_red.py (optimo = %.4f)",
                    tier, optimum)
        # La particion optima ya viene en el JSON, en el orden de variables.
        cadena = (payload.get("baselines", {}).get("maxcut", {})
                  .get("brute_force", {}).get("bitstring"))
        if cadena and len(cadena) == len(variable_order):
            bits_opt = {nodo: int(b) for nodo, b in zip(variable_order, cadena)}

    # -----------------------------------------------------------------------
    # SUMA DE PESOS Y FRACCION SECCIONADA
    # -----------------------------------------------------------------------
    # La suma total es la referencia contra la que se mide cuanto de la red
    # queda seccionado. Ademas es la cantidad con la que modelador_red.py
    # autocalibra la penalizacion critica (beta >= 2*sumW).
    #
    # Lo que revela: Max-Cut MAXIMIZA el corte, asi que el optimo suele
    # seccionar casi todo el peso de la instancia. No esta partiendo la red en
    # dos zonas, la esta fragmentando. El particionamiento en zonas de falla
    # busca lo contrario: el corte MINIMO que aisle, con cada isla capaz de
    # sostenerse sola. Esta divergencia entre el planteamiento del reto y el
    # criterio operativo debe reportarse con cifras, no omitirse.
    # -----------------------------------------------------------------------
    suma_pesos = float(sum(float(a["weight"]) for a in edges))
    frac_peso = optimum / suma_pesos if suma_pesos > 0 else float("nan")
    unidad = " km" if WEIGHT_MODE == "longitud" else ""
    if bits_opt:
        n_cortadas = sum(1 for a in edges if bits_opt[a["u"]] != bits_opt[a["v"]])
        km_total = sum(float(a.get("length_m", 0.0)) for a in edges) / 1000.0
        km_cortados = sum(float(a.get("length_m", 0.0)) for a in edges
                          if bits_opt[a["u"]] != bits_opt[a["v"]]) / 1000.0
        logger.info("[%s] suma de pesos = %.4f%s | el optimo secciona %.1f%% "
                    "del peso total, %d de %d lineas (%.2f de %.2f km)",
                    tier, suma_pesos, unidad, 100.0 * frac_peso,
                    n_cortadas, len(edges), km_cortados, km_total)
    else:
        logger.info("[%s] suma de pesos = %.4f%s | el optimo secciona %.1f%% "
                    "del peso total", tier, suma_pesos, unidad,
                    100.0 * frac_peso)

    # -----------------------------------------------------------------------
    # ALINEACION ENTRE EL CIRCUITO Y LA PUNTUACION
    # -----------------------------------------------------------------------
    # El h y el J del JSON pertenecen a H_total, que ademas del corte incluye
    # el balance de potencia y la restriccion critica (la carga critica junto
    # a su ancla de generacion), con penalizaciones grandes. Pero la funcion
    # que puntua los shots, valor_corte, mide UNICAMENTE el corte ponderado.
    #
    # Usar el h y el J del JSON hacia que el circuito optimizara tres reglas
    # mientras el resultado se calificaba con una sola. Los angulos que hacen
    # bien las tres no son los que maximizan el corte, y el resultado se
    # estancaba muy por debajo de lo alcanzable.
    #
    # Aqui se construye el Ising de Max-Cut PURO desde las aristas:
    #     corte = sum_ij w_ij (1 - s_i s_j) / 2
    #     maximizar el corte  <=>  minimizar  sum_ij (w_ij / 2) s_i s_j
    # Es cuadratico puro, asi que el campo local h es cero.
    #
    # La formulacion completa con penalizaciones sigue existiendo, verificada
    # y documentada en modelador_red.py (checks 2, 3 y 7): cubre el punto de
    # la rubrica sobre terminos de penalizacion documentados. Lo que cambia
    # es que el CIRCUITO resuelve el mismo problema que se mide y que
    # resuelven greedy y Goemans-Williamson, de modo que las tres cifras son
    # directamente comparables.
    # -----------------------------------------------------------------------
    idx = {nodo: i for i, nodo in enumerate(variable_order)}
    h = np.zeros(n, dtype=np.float64)
    j_upper = np.zeros((n, n), dtype=np.float64)
    for arista in edges:
        i, j = sorted((idx[arista["u"]], idx[arista["v"]]))
        j_upper[i, j] += float(arista["weight"]) / 2.0

    logger.info("[%s] Ising de Max-Cut puro construido desde %d aristas "
                "(h = 0, |J|max = %.4f). H_total del JSON: |J|max = %.4f, "
                "no se usa para el circuito.",
                tier, len(edges), float(np.abs(j_upper).max()),
                float(np.abs(j_json).max()))

    # Comprobacion de que el circuito y la puntuacion resuelven el mismo
    # problema. Con J_ij = w_ij/2 debe cumplirse, para CUALQUIER particion:
    #     corte(s) + energia_Ising(s) = suma_total_de_pesos / 2 = constante
    # Si la desviacion de esa suma no es cero, los dos lados miden cosas
    # distintas y ningun resultado posterior significa nada. Este es el
    # desalineamiento que hacia que r se estancara.
    rng_chk = np.random.default_rng(0)
    residuos = []
    for _ in range(100):
        vals = rng_chk.integers(0, 2, size=n)
        bits_chk = {nodo: int(b) for nodo, b in zip(variable_order, vals)}
        s = np.array([1 - 2 * bits_chk[nodo] for nodo in variable_order],
                     dtype=np.float64)
        corte_chk = valor_corte(edges, bits_chk)
        energia_chk = float(s @ np.triu(j_upper, 1) @ s)
        residuos.append(corte_chk + energia_chk)
    desv = float(np.std(residuos))
    if desv < 1e-9:
        logger.info("[%s] alineacion circuito/puntuacion: OK "
                    "(residuo constante = %.4f)", tier, float(np.mean(residuos)))
    else:
        logger.error("[%s] alineacion circuito/puntuacion: FALLA "
                     "(desv = %.2e). El circuito optimiza algo distinto de lo "
                     "que se mide; los resultados no serian validos.",
                     tier, desv)
        return None

    return {"tier": tier, "variable_order": variable_order, "h": h,
            "J_upper": j_upper, "edges": edges, "optimum": optimum,
            "n": n, "h_json": h_json, "J_json": j_json,
            "weight_mode": WEIGHT_MODE, "greedy_local": greedy_local,
            "suma_pesos": suma_pesos, "frac_peso_optimo": frac_peso}


# ===========================================================================
# 2. Corte ponderado de un bitstring (misma definicion que la Fase 1)
# ===========================================================================
def valor_corte(edges: list[dict], bits: dict[str, int]) -> float:
    """Suma de pesos de las aristas cuyos extremos caen en islas distintas.
    Identica a la usada por greedy y GW, para que los numeros sean
    directamente comparables. NO es la energia del Ising."""
    total = 0.0
    for arista in edges:
        u, v, w = arista["u"], arista["v"], float(arista["weight"])
        if bits[u] != bits[v]:
            total += w
    return total


# ===========================================================================
# 3. Circuito QAOA de p capas desde el Hamiltoniano Ising
# ===========================================================================
def construir_circuito_qaoa(n: int, h: np.ndarray, j_upper: np.ndarray,
                             gammas: np.ndarray, betas: np.ndarray) -> Circuit:
    """QAOA de p capas. Por cada capa k:
        Hamiltoniano de costo (gamma_k):
            campo local h_i -> Rz(2*gamma_k*h_i)
            acople J_ij     -> CX(i,j) . Rz(2*gamma_k*J_ij) . CX(i,j)
        Hamiltoniano de mezcla (beta_k): Rx(2*beta_k) en cada qubit.
    Antes: Hadamard en todos (superposicion uniforme). Al final: medicion.
    Los angulos de pytket van en unidades de PI, de ahi la division."""
    p = len(gammas)
    circ = Circuit(n, n)

    for q in range(n):
        circ.H(q)

    for k in range(p):
        gamma, beta = float(gammas[k]), float(betas[k])
        for i in range(n):
            if abs(h[i]) > 1e-12:
                circ.Rz(2.0 * gamma * h[i] / np.pi, i)
        for i in range(n):
            for j in range(i + 1, n):
                jij = j_upper[i, j]
                if abs(jij) > 1e-12:
                    circ.CX(i, j)
                    circ.Rz(2.0 * gamma * jij / np.pi, j)
                    circ.CX(i, j)
        for q in range(n):
            circ.Rx(2.0 * beta / np.pi, q)

    for q in range(n):
        circ.Measure(q, q)

    return circ


# ===========================================================================
# 4. Backend: local (Qulacs) o H2 (emulador Quantinuum via qnexus)
# ===========================================================================
def obtener_backend():
    """Devuelve (backend, etiqueta) segun la variable global BACKEND."""
    if BACKEND == "local":
        from pytket.extensions.qulacs import QulacsBackend
        logger.info("Backend LOCAL: QulacsBackend (simulador, sin costo)")
        return QulacsBackend(), "local-qulacs"

    if BACKEND == "h2":
        import qnexus as qnx
        from pytket.extensions.quantinuum import QuantinuumBackend
        logger.info("Backend H2: %s via qnexus (proyecto %s)",
                    EMULATOR_NAME, NEXUS_PROJECT)
        # AVISO DE COSTO. Cada iteracion del optimizador es una corrida
        # completa del circuito. Con el arranque en caliente (36 puntos de
        # cuadricula) mas 5 corridas x 200 iteraciones, un solo (tier, p) son
        # ~1036 corridas de circuito. El barrido completo de 3 tiers x 3
        # valores de p son ~9300 corridas. En un emulador remoto eso es
        # inviable en tiempo y en cuota.
        #
        # Para la entrega, lo razonable es una corrida ACOTADA en H2 que
        # demuestre ejecucion en la plataforma, y el barrido completo en
        # local. Por ejemplo:
        #   --backend h2 --tiers mvp8 --p-values 1 --n-runs 1 --shots 200
        # y reportar esa cifra junto a la local, senalando la diferencia.
        logger.warning("H2 cobra por corrida. El barrido completo son ~9300 "
                       "corridas de circuito. Considera acotar el alcance: "
                       "--tiers mvp8 --p-values 1 --n-runs 1 --shots 200")
        qnx.projects.get_or_create(name=NEXUS_PROJECT)
        backend = QuantinuumBackend(device_name=EMULATOR_NAME)
        backend.login()
        return backend, f"h2-{EMULATOR_NAME}"

    raise ValueError(f"BACKEND desconocido: {BACKEND!r} (usar 'local' o 'h2')")


# ===========================================================================
# 5. Evaluacion de un vector de angulos
# ===========================================================================
def evaluar_angulos(params: np.ndarray, instancia: dict, backend, shots: int,
                    p: int) -> tuple[float, float, dict[str, int]]:
    """Corre el circuito con los angulos dados (primeros p = gammas,
    ultimos p = betas) y devuelve (corte_promedio, mejor_corte,
    mejor_bitstring).

    El PRIMER valor (corte_promedio) es el que se optimiza y se reporta.
    Los otros dos quedan solo como dato secundario, para mostrar una
    particion concreta."""
    n = instancia["n"]
    variable_order = instancia["variable_order"]
    edges = instancia["edges"]
    gammas, betas = params[:p], params[p:]

    circ = construir_circuito_qaoa(n, instancia["h"], instancia["J_upper"],
                                    gammas, betas)
    circ = backend.get_compiled_circuit(circ)
    counts = backend.run_circuit(circ, n_shots=shots).get_counts()

    suma, total = 0.0, 0
    mejor_corte, mejor_bits = -np.inf, {}
    for lectura, veces in counts.items():
        bits = {variable_order[q]: int(lectura[q]) for q in range(n)}
        corte = valor_corte(edges, bits)
        suma += corte * veces
        total += veces
        if corte > mejor_corte:
            mejor_corte, mejor_bits = corte, bits

    return (suma / total if total else 0.0), mejor_corte, mejor_bits


# ===========================================================================
# 6. Una ejecucion: optimizacion de angulos desde un arranque dado
# ===========================================================================
def una_ejecucion(instancia: dict, backend, shots: int, p: int,
                  optimizer: str, x0: np.ndarray) -> dict[str, Any]:
    """Optimizacion completa desde x0. Como scipy minimiza, se minimiza el
    negativo del corte = maximizar (consistencia max/min).

    Se optimiza y se reporta el corte PROMEDIO sobre los shots (la esperanza),
    no el mejor shot. La rubrica define r = E_QAOA / E_optimo, con E de
    esperanza. Quedarse con el mejor de los shots satura en r = 1.0000 en
    instancias chicas incluso sin optimizar: con 8 qubits hay 256 estados y
    la superposicion uniforme inicial ya toca el optimo en ~999 de cada 1000
    tiros para cualquier angulo. El sintoma es desviacion estandar 0.0000
    entre corridas con arranques distintos."""
    mejor = {"corte": -np.inf, "bits": {}, "params": None}

    def objetivo(params: np.ndarray) -> float:
        corte_medio, _, bits = evaluar_angulos(params, instancia, backend,
                                               shots, p)
        if corte_medio > mejor["corte"]:
            mejor.update(corte=corte_medio, bits=bits, params=params.copy())
        return -corte_medio

    if optimizer.upper() == "BFGS":
        minimize(objetivo, x0, method="BFGS", options={"maxiter": 200})
    else:
        # rhobeg es el tamano del primer paso que da COBYLA. Con gamma ahora
        # sorteado en [0, pi/|J|max], un paso de 0.5 saltaria fuera del rango
        # util en el primer intento y el escalado de arriba no serviria de
        # nada. Se ajusta al mismo orden de magnitud.
        escala_j = max(float(np.abs(instancia["J_upper"]).max()), 1e-9)
        paso = min(0.5, (np.pi / escala_j) / 2.0)
        # maxiter = 200: con 2*p angulos por ajustar, 40 iteraciones cortaban
        # la optimizacion antes de que convergiera. Cada iteracion equivale a
        # una corrida del circuito con n_shots disparos, asi que el tiempo
        # total sube en proporcion.
        minimize(objetivo, x0, method="COBYLA",
                 options={"maxiter": 200, "rhobeg": paso})

    ratio = (mejor["corte"] / instancia["optimum"]
             if instancia["optimum"] > 0 else float("nan"))
    return {"cut": float(mejor["corte"]), "ratio": float(ratio),
            "bits": mejor["bits"]}


# ===========================================================================
# 6a. Arranque en caliente: busqueda en cuadricula previa
# ===========================================================================
def arranque_en_caliente(instancia: dict, backend, shots: int, p: int,
                         n_puntos: int = 6) -> tuple[np.ndarray, float]:
    """Prueba una cuadricula gruesa de angulos y devuelve el mejor punto.

    QUE HACE, EN SIMPLE
    Antes de empezar a afinar, se prueban unas pocas posiciones repartidas
    por todo el rango de las dos perillas y se anota cual dio mejor
    resultado. La optimizacion fina arranca desde ahi, en vez de desde un
    punto al azar que puede caer en una zona mala.

    POR QUE
    COBYLA es un optimizador local: mejora desde donde lo pongas, pero no
    sale de un mal barrio. Arrancar al azar significa que a veces cae en una
    zona sin nada bueno cerca y se estanca. La rubrica lista esto entre las
    soluciones a "el optimizador no converge": arranque en caliente desde una
    busqueda en cuadricula.

    COSTO
    n_puntos^2 corridas del circuito, con los mismos angulos repetidos en
    todas las capas (es una exploracion gruesa, no una optimizacion). Con
    n_puntos=6 son 36 corridas, frente a las 200 iteraciones que despues
    hara COBYLA.

    Devuelve (vector de 2*p angulos, valor del corte promedio en ese punto).
    """
    escala_j = max(float(np.abs(instancia["J_upper"]).max()), 1e-9)
    # gamma se recorre en el rango escalado (una vuelta completa como maximo)
    # y beta en [0, pi], que es su periodo natural en las compuertas Rx.
    rejilla_gamma = np.linspace(0.0, np.pi / escala_j, n_puntos)
    rejilla_beta = np.linspace(0.0, np.pi, n_puntos)

    mejor_valor, mejor_x0 = -np.inf, None
    for g in rejilla_gamma:
        for b in rejilla_beta:
            # Mismo angulo en todas las capas: es un tanteo grueso, no una
            # solucion. COBYLA despues los separa capa por capa.
            x = np.concatenate([np.full(p, g), np.full(p, b)])
            valor, _, _ = evaluar_angulos(x, instancia, backend, shots, p)
            if valor > mejor_valor:
                mejor_valor, mejor_x0 = valor, x

    logger.info("[%s] p=%d arranque en caliente: mejor de %d puntos de "
                "cuadricula -> corte promedio %.4f (gamma=%.4f, beta=%.4f)",
                instancia["tier"], p, n_puntos * n_puntos, mejor_valor,
                float(mejor_x0[0]), float(mejor_x0[p]))
    return mejor_x0, float(mejor_valor)


# ===========================================================================
# 7. n_runs ejecuciones con distintas inicializaciones -> estadistica
# ===========================================================================
def resolver_instancia(instancia: dict, backend, shots: int, p: int,
                       n_runs: int, optimizer: str, seed: int) -> dict[str, Any]:
    """Corre n_runs optimizaciones independientes con arranques distintos.
    Reporta media y desviacion estandar (lo que exige la rubrica) y ademas
    el mejor y el peor, para transparencia."""
    tier = instancia["tier"]
    rng = np.random.default_rng(seed)
    escala_j = max(float(np.abs(instancia["J_upper"]).max()), 1e-9)

    # Arranque en caliente: una sola busqueda en cuadricula por (tier, p),
    # reutilizada por las n_runs corridas.
    x0_caliente, valor_caliente = arranque_en_caliente(instancia, backend,
                                                       shots, p)

    ratios, cortes = [], []
    for run in range(n_runs):
        if run == 0:
            # La primera corrida arranca exactamente en el mejor punto de la
            # cuadricula.
            x0 = x0_caliente.copy()
        else:
            # Las demas arrancan cerca de ese punto, pero NO en el mismo, con
            # una perturbacion del 30% del rango de cada perilla.
            #
            # Por que no todas desde el mismo punto: la rubrica exige media y
            # desviacion sobre 5 o mas corridas con INICIALIZACIONES
            # DISTINTAS. Cinco corridas identicas darian desviacion 0.0000,
            # que es exactamente el sintoma del bug anterior, y ademas no
            # informarian nada sobre la estabilidad del metodo.
            #
            # Por que cerca y no al azar puro: asi todas parten de una zona
            # buena (ese es el beneficio del arranque en caliente) pero
            # exploran alrededores distintos.
            ruido_g = rng.normal(0.0, 0.30 * np.pi / escala_j, size=p)
            ruido_b = rng.normal(0.0, 0.30 * np.pi, size=p)
            x0 = x0_caliente + np.concatenate([ruido_g, ruido_b])

        res = una_ejecucion(instancia, backend, shots, p, optimizer, x0)
        ratios.append(res["ratio"])
        cortes.append(res["cut"])
        logger.info("[%s] p=%d run %d/%d: cut=%.4f  r=%.4f",
                    tier, p, run + 1, n_runs, res["cut"], res["ratio"])

    ratios, cortes = np.array(ratios), np.array(cortes)
    return {
        "tier": tier, "p": p, "n_runs": n_runs, "optimizer": optimizer,
        "optimum": instancia["optimum"],
        "weight_mode": instancia.get("weight_mode"),
        # Suma de pesos de la instancia y que fraccion secciona el optimo.
        # Deja registrado en el JSON el hallazgo de que Max-Cut fragmenta
        # casi toda la red en vez de partirla en dos zonas.
        "suma_pesos": instancia.get("suma_pesos"),
        "frac_peso_optimo": instancia.get("frac_peso_optimo"),
        "arranque": "cuadricula + perturbacion",
        "cut_cuadricula": valor_caliente,
        # cifra principal reportada (sin cherry-picking)
        "cut_mean": float(cortes.mean()), "cut_std": float(cortes.std()),
        "ratio_mean": float(ratios.mean()), "ratio_std": float(ratios.std()),
        # datos secundarios, solo para transparencia
        "cut_best": float(cortes.max()), "ratio_best": float(ratios.max()),
        "ratio_worst": float(ratios.min()),
    }


# ===========================================================================
# 8. Barrido de p y figura obligatoria "razon vs p"
# ===========================================================================
def barrer_p(scratch_dir: Path, tiers: list[str], p_values: list[int],
             shots: int, n_runs: int, optimizer: str, seed: int
             ) -> dict[str, list[dict[str, Any]]]:
    """Para cada instancia y cada p, corre el bloque completo de n_runs
    ejecuciones. Devuelve {tier: [res_p1, res_p2, ...]}."""
    backend, etiqueta = obtener_backend()
    logger.info("Barrido p=%s sobre %s | backend=%s | n_runs=%d | shots=%d",
                p_values, tiers, etiqueta, n_runs, shots)

    resultados: dict[str, list[dict[str, Any]]] = {}
    for tier in tiers:
        instancia = cargar_instancia(scratch_dir, tier)
        if instancia is None:
            continue
        serie = []
        for p in p_values:
            logger.info("[%s] p=%d (%d qubits, %d ejecuciones)...",
                        tier, p, instancia["n"], n_runs)
            res = resolver_instancia(instancia, backend, shots, p, n_runs,
                                     optimizer, seed)
            res["backend"] = etiqueta
            serie.append(res)
            print(f"  [{tier}] p={p}: r = {res['ratio_mean']:.4f} "
                  f"+/- {res['ratio_std']:.4f}   "
                  f"(mejor {res['ratio_best']:.4f}, peor {res['ratio_worst']:.4f})")
        resultados[tier] = serie
    return resultados


def graficar_r_vs_p(resultados: dict[str, list[dict[str, Any]]],
                    out_path: Path) -> Path | None:
    """Figura obligatoria: razon de aproximacion vs p, con barras de error
    (desviacion estandar sobre las n_runs ejecuciones) y las cotas teoricas
    de GW y de QAOA p=1 que cita la rubrica."""
    if not resultados:
        logger.warning("Sin resultados: no se genera figura")
        return None

    fig, ax = plt.subplots(figsize=(8, 5))
    for tier, serie in resultados.items():
        ps = [r["p"] for r in serie]
        medias = [r["ratio_mean"] for r in serie]
        stds = [r["ratio_std"] for r in serie]
        ax.errorbar(ps, medias, yerr=stds, marker="o", capsize=4,
                    label=f"{tier} (media +/- desv. est.)")

    ax.axhline(GW_GUARANTEE, color="black", linestyle="--", linewidth=1,
               label=f"Garantia GW ({GW_GUARANTEE})")
    ax.axhline(QAOA_P1_GUARANTEE, color="gray", linestyle=":", linewidth=1,
               label=f"Garantia QAOA p=1 ({QAOA_P1_GUARANTEE})")

    todos_p = sorted({r["p"] for serie in resultados.values() for r in serie})
    ax.set_xticks(todos_p)
    ax.set_xlabel("Numero de capas p")
    ax.set_ylabel("Razon de aproximacion r = corte / optimo")
    ax.set_title("QAOA: razon de aproximacion vs p - Proyecto Isla Verde")
    ax.set_ylim(0, 1.05)
    ax.legend(loc="lower right", fontsize=8)
    ax.grid(alpha=0.3)
    fig.tight_layout()
    fig.savefig(out_path, dpi=150)
    plt.close(fig)
    logger.info("Figura guardada en %s", out_path)
    return out_path


# ===========================================================================
# 9. Etapas clasicas: se invocan los scripts existentes del repo
# ===========================================================================
def ejecutar_script(descripcion: str, comando: list[str]) -> bool:
    """Corre un script externo mostrando su salida en vivo."""
    print("\n" + "=" * 70)
    print(f">>> {descripcion}")
    print("    " + " ".join(comando))
    print("=" * 70)
    if subprocess.run(comando).returncode != 0:
        print(f"\n[ERROR] Etapa fallida: {descripcion}")
        return False
    return True


# ===========================================================================
# 10. Orquestacion completa
# ===========================================================================
def run(data_dir: Path, scratch_dir: Path, tiers: list[str],
        p_values: list[int], shots: int, n_runs: int, optimizer: str,
        seed: int, solo_cuantico: bool) -> int:
    py = sys.executable

    # --- Etapa 1 (clasica): grafo, QUBO/Ising, lineas base --------------
    if not solo_cuantico:
        if not ejecutar_script(
            "Etapa 1/3 - Modelado de la red y lineas base clasicas",
            [py, "modelador_red.py", "--data-dir", str(data_dir),
             "--out-dir", str(scratch_dir), "--seed", str(seed)],
        ):
            return 1

    # --- Etapa 2 (cuantica): barrido de p con estadistica y figura ------
    print("\n" + "=" * 70)
    print(">>> Etapa 2/3 - QAOA: barrido de p, estadistica y figura r vs p")
    print("=" * 70)
    resultados = barrer_p(scratch_dir, tiers, p_values, shots, n_runs,
                          optimizer, seed)
    if not resultados:
        logger.error("Ninguna instancia disponible en %s", scratch_dir)
        return 1

    scratch_dir.mkdir(parents=True, exist_ok=True)
    with open(scratch_dir / "qaoa_barrido_p.json", "w", encoding="utf-8") as f:
        json.dump(resultados, f, indent=2, ensure_ascii=False)
    graficar_r_vs_p(resultados, scratch_dir / "qaoa_ratio_vs_p.png")

    # Tabla resumen: media +/- std por p (cifra principal de la rubrica).
    print("\n=== Razon de aproximacion vs p (media +/- desv. estandar) ===")
    encabezado = f"{'instancia':<12}" + "".join(
        f"{'p=' + str(p):>24}" for p in p_values)
    print(encabezado)
    print("-" * len(encabezado))
    for tier, serie in resultados.items():
        fila = f"{tier:<12}"
        for res in serie:
            fila += f"{res['ratio_mean']:>15.4f} +/- {res['ratio_std']:<6.4f}"
        print(fila)

    # JSON para la Fase 2. Se reporta la MEDIA, no la mejor corrida:
    # la rubrica marca el cherry-picking como red flag.
    p_reporte = p_values[-1]
    resultados_fase2 = {}
    for tier, serie in resultados.items():
        res = next(r for r in serie if r["p"] == p_reporte)
        resultados_fase2[tier] = {"cut": res["cut_mean"], "p": p_reporte}
    ruta_fase2 = scratch_dir / "qaoa_results.json"
    with open(ruta_fase2, "w", encoding="utf-8") as f:
        json.dump(resultados_fase2, f, indent=2, ensure_ascii=False)
    logger.info("Resultados para Fase 2 (media, p=%d) en %s",
                p_reporte, ruta_fase2)

    # --- Etapa 3 (clasica): comparacion QAOA vs lineas base -------------
    # En modo "longitud" NO se corre: comparar_qaoa.py lee del JSON las
    # lineas base calculadas con el peso de acoplamiento, y mezclarlas con
    # cortes en km daria una tabla sin sentido. Las cifras de fuerza bruta y
    # greedy con los pesos nuevos ya se imprimieron al cargar cada instancia.
    if WEIGHT_MODE == "longitud":
        print("\n" + "=" * 70)
        print("Etapa 3 OMITIDA en modo 'longitud'.")
        print("=" * 70)
        print("Las lineas base del JSON (fuerza bruta, greedy, GW) fueron")
        print("calculadas con el peso de acoplamiento y no son comparables")
        print("con cortes medidos en km.")
        print()
        print("La fuerza bruta y el greedy con los pesos nuevos se calcularon")
        print("aqui y aparecen en el log de cada instancia.")
        print()
        print("Para tener tambien Goemans-Williamson con estos pesos, hay que")
        print("recalcularlo en el modelador (necesita la relajacion SDP de")
        print("cvxpy, que no vive en este archivo).")
        print()
        print("Lo comparable entre los dos modos son las RAZONES de")
        print("aproximacion y las PARTICIONES, no los cortes en bruto.")
        return 0

    if not ejecutar_script(
        "Etapa 3/3 - Comparacion QAOA vs lineas base clasicas",
        [py, "comparar_qaoa.py", "--scratch-dir", str(scratch_dir),
         "--tiers", *tiers, "--qaoa-results", str(ruta_fase2)],
    ):
        return 1

    # --- Inventario de artefactos ---------------------------------------
    print("\n" + "=" * 70)
    print("REPRODUCCION COMPLETA. Artefactos en:", scratch_dir)
    print("=" * 70)
    esperados = [
        "isla_verde_mvp8.json", "isla_verde_std12.json",
        "isla_verde_large16.json", "isla_verde_full_graph.json",
        "isla_verde_index.json", "isla_verde_red_230kv.png",
        "qaoa_barrido_p.json", "qaoa_ratio_vs_p.png",
        "qaoa_results.json", "comparacion_qaoa_vs_clasico.png",
    ]
    for nombre in esperados:
        marca = "OK" if (scratch_dir / nombre).exists() else "--"
        print(f"  [{marca}] {nombre}")

    print("\nRecordatorio para el informe (limitaciones honestas):")
    print("  - QAOA no supera a GW para Max-Cut; en p=1 su garantia (0.6924)")
    print("    es inferior a la de GW (0.878).")
    print("  - Los balances B_i son sinteticos: los CSV del ICE no traen MW.")
    print("  - El peso 1/longitud es un proxy de acoplamiento, no capacidad.")
    print("  - HALLAZGO MEDIDO (ver comparar_criterios.py): bajo las DOS")
    print("    definiciones de peso, la particion optima secciona casi todas")
    print("    las lineas de la instancia y deja las islas desbalanceadas.")
    print("    Max-Cut MAXIMIZA el corte, mientras que el islanding fisico")
    print("    busca MINIMIZARLO sujeto a autosuficiencia de cada isla. El")
    print("    planteamiento del reto y el criterio operativo divergen, y")
    print("    conviene reportarlo con las cifras en vez de omitirlo.")
    return 0


def parse_args(argv: list[str] | None = None):
    parser = argparse.ArgumentParser(
        description="ISLA VERDE - Fase cuantica completa (punto de entrada unico)"
    )
    parser.add_argument("--data-dir", type=Path, default=Path("data"),
                        help="carpeta con los CSV del ICE")
    parser.add_argument("--scratch-dir", type=Path, default=Path("scratch"),
                        help="carpeta de salida de todos los artefactos")
    parser.add_argument("--tiers", nargs="+",
                        default=["mvp8", "std12", "large16"])
    parser.add_argument("--p-values", nargs="+", type=int, default=[1, 2, 3],
                        help="valores de p a barrer")
    parser.add_argument("--shots", type=int, default=1000)
    parser.add_argument("--n-runs", type=int, default=5,
                        help="ejecuciones por punto (rubrica: >=5)")
    parser.add_argument("--optimizer", type=str, default="COBYLA",
                        choices=["COBYLA", "BFGS"],
                        help="BFGS si COBYLA no converge")
    parser.add_argument("--seed", type=int, default=42)
    parser.add_argument("--backend", type=str, default="local",
                        choices=["local", "h2"],
                        help="local = Qulacs (gratis); h2 = emulador Quantinuum")
    parser.add_argument("--weight-mode", type=str, default="acoplamiento",
                        choices=["acoplamiento", "longitud"],
                        help="acoplamiento (POR DEFECTO) = peso 1e5/longitud "
                             "del JSON: Max-Cut secciona las lineas CORTAS. "
                             "Mantiene validas las lineas base del modelador, "
                             "asi que se genera la tabla comparativa completa "
                             "con GW. "
                             "longitud = peso longitud_km: secciona las lineas "
                             "LARGAS. En ese modo se recalculan aqui la fuerza "
                             "bruta y el greedy, y se omite la comparacion "
                             "contra GW.")
    parser.add_argument("--solo-cuantico", action="store_true",
                        help="omite la etapa clasica (si ya corriste modelador_red.py)")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    global BACKEND, WEIGHT_MODE
    logging.basicConfig(level=logging.INFO,
                        format="%(levelname)s %(name)s: %(message)s")
    args = parse_args(argv)
    BACKEND = args.backend
    WEIGHT_MODE = args.weight_mode
    return run(args.data_dir, args.scratch_dir, args.tiers, args.p_values,
               args.shots, args.n_runs, args.optimizer, args.seed,
               args.solo_cuantico)


if __name__ == "__main__":
    sys.exit(main())
